NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id-here

# Server-only LayerZero VT API key. Read by app/api/vt/[...path]/route.ts and
# injected into the upstream request as the `x-api-key` header. NOT exposed
# to the browser — do not add the NEXT_PUBLIC_ prefix.
VT_API_KEY=

# Optional: override the upstream VT API base URL (e.g. for staging).
# Defaults to https://transfer.layerzero-api.com/v1.
# VT_API_UPSTREAM=
